function buildCatButtons(){
  catBtns.innerHTML = '';
  activeCat = null;
  const cats = categorieen[verzekering.value];
  if(!cats){ smartResult.innerHTML = ''; return; }
  // Altijd toon "Alles" knop
  const allBtn = document.createElement('button');
  allBtn.textContent = 'Alles';
  allBtn.style.cssText = 'padding:10px 18px;border-radius:999px;border:1px solid var(--border);background:var(--primary);color:white;cursor:pointer;font:inherit';
  allBtn.onclick = () => { activeCat = null; highlightBtn(allBtn); renderTable(); smartResult.innerHTML = ''; };
  catBtns.appendChild(allBtn);

  Object.keys(cats).forEach(cat => {
    const btn = document.createElement('button');
    btn.textContent = cat;
    btn.dataset.cat = cat;
    btn.style.cssText = 'padding:10px 18px;border-radius:999px;border:1px solid var(--border);background:var(--surface2);color:var(--text);cursor:pointer;font:inherit';
    btn.onclick = () => { activeCat = cat; highlightBtn(btn); renderSmart(cat); renderTable(); };
    catBtns.appendChild(btn);
  });
}

function highlightBtn(active){
  catBtns.querySelectorAll('button').forEach(b => {
    b.style.background = 'var(--surface2)';
    b.style.color = 'var(--text)';
  });
  active.style.background = 'var(--primary)';
  active.style.color = 'white';
}

function renderSmart(cat){
  const engine = rulesEngine[verzekering.value];
  if(!engine){ smartResult.innerHTML = ''; return; }
  // Haal alle keys op uit de engine voor deze categorie via toString
  const src = engine.toString();
  const re = /'([^']+)':\s*\[\[/g;
  let match;
  const catFilter = categorieen[verzekering.value]?.[cat];
  const allKeys = [];
  while((match = re.exec(src)) !== null){ allKeys.push(match[1]); }

  // Roep engine aan voor elke key en filter op categorie
  const results = [];
  allKeys.forEach(k => {
    const res = engine(k);
    if(res && res.length){
      res.forEach(([c,o]) => {
        if(!catFilter || catFilter(c)){
          if(!results.find(r => r[0]===c)) results.push([c,o]);
        }
      });
    }
  });

  if(!results.length){
    smartResult.innerHTML = '<div class="rule">Geen codes gevonden voor deze categorie.</div>';
    return;
  }
  if(!results.length){ smartResult.innerHTML = '<div class="rule">Geen codes gevonden.</div>'; return; }
  smartResult.innerHTML = results.map(([c,o]) => `<div class="rule"><strong>${c}</strong> — ${o}</div>`).join('');
}

function renderTable(){
  const item = data[verzekering.value];
  const q = zoek.value.toLowerCase().trim();
  const catFilter = activeCat ? categorieen[verzekering.value]?.[activeCat] : null;
  const rows = item.codes.filter(([c,o]) => {
    const zoekMatch = !q || (c + ' ' + o).toLowerCase().includes(q);
    const catMatch = !catFilter || catFilter(c);
    return zoekMatch && catMatch;
  });
  tbody.innerHTML = rows.map(([c,o]) => `<tr><td><strong>${c}</strong></td><td>${o}</td></tr>`).join('');
}

names.forEach(n => {
  const o = document.createElement('option'); o.value=n; o.textContent=n; verzekering.appendChild(o);
  const c = document.createElement('span'); c.className='chip'; c.textContent=n; c.onclick=()=>{verzekering.value=n; render();}; chips.appendChild(c);
});

function render(){
  const item = data[verzekering.value];
  merken.textContent = 'Labels / gekoppelde verzekeringen: ' + item.verzekeraars.join(', ');
  regels.innerHTML = item.regels.map(r => `<div class="rule">${r}</div>`).join('');
  activeCat = null;
  buildCatButtons();
  renderTable();
}
verzekering.value = 'DSW';
verzekering.addEventListener('change', render);
render();
const mq = window.matchMedia('(prefers-color-scheme: dark)');
document.documentElement.setAttribute('data-theme', mq.matches ? 'dark' : 'light');
mq.addEventListener('change', e => document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light'));
</script>
